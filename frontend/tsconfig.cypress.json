{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["cypress", "node"],
    "isolatedModules": false
  },
  "include": ["cypress.config.ts", "cypress/**/*.ts"]
}
