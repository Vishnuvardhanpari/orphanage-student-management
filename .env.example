# Copy this file to `.env` in the repository root and adjust values for local development.
# Never commit `.env` — it may contain secrets.

# --- Spring Boot ---
# Use `local` for IDE/shell runs (matches README). Profile `dev` is equivalent today.
SPRING_PROFILES_ACTIVE=local

# --- PostgreSQL (local Docker via infra/docker-compose.yml) ---
# Required: set a strong DB_PASSWORD before `docker compose up`.
# Compose will refuse to start if DB_PASSWORD is empty.
DB_HOST=localhost
# Default host port is 5432. If that port is already in use (common on Windows),
# set DB_PORT=5433 in your local `.env` (do not commit `.env`).
DB_PORT=5432
DB_NAME=oms_dev
DB_USERNAME=oms_user
DB_PASSWORD=

# Optional: override CORS origins (comma-separated). Defaults to http://localhost:4200 for local/dev.
# OMS_CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- JWT (Milestone 2+) ---
# Must be at least 32 characters (256 bits) for HS256.
JWT_SECRET=change_me_use_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=oms

# --- Account lockout ---
OMS_LOCKOUT_MAX_ATTEMPTS=5
OMS_LOCKOUT_DURATION_MINUTES=15

# --- Bootstrap admin (created only when users table is empty) ---
OMS_BOOTSTRAP_ADMIN_USERNAME=admin
OMS_BOOTSTRAP_ADMIN_EMAIL=admin@oms.local
OMS_BOOTSTRAP_ADMIN_PASSWORD=12345678

# --- Google OAuth2 (Milestone 2+) ---
# GIS client ID used by Angular and backend ID-token verification.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Cloud Storage (Milestone 5+) ---
# Production: private student-documents bucket name (not the SPA bucket).
GCS_BUCKET_NAME=

# --- Production / Supabase (Milestone 15+) ---
# JDBC SSL mode appended in application-prod.yml (default require).
# DB_SSL_MODE=require
# Public SPA origin used for CORS when not same-origin-only (set to https://your.domain).
# OMS_CORS_ALLOWED_ORIGINS=https://app.example.com

# --- Reports / PDF export (Milestone 10+) ---
# OMS_REPORTS_ORGANIZATION_NAME=Orphanage Management System
# OMS_REPORTS_MAX_SELECTED=50
# OMS_REPORTS_MAX_FILTER=100
